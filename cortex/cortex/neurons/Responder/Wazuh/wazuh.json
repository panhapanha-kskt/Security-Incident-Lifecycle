{
  "name": "Wazuh",
  "version": "1.0",
  "author": "Wes Lambert",
  "url": "https://github.com/TheHive-Project/Cortex-Analyzers",
  "license": "AGPL-V3",
  "description": "Block an IP on a host via Wazuh agent",
  "dataTypeList": [
    "thehive:case",
    "thehive:case_artifact"
  ],
  "command": "Wazuh/wazuh.py",
  "baseConfig": "Wazuh",
  "configurationItems": [
    {
      "name": "wazuh_manager",
      "description": "URL for Wazuh Manager",
      "type": "string",
      "multi": false,
      "required": true,
      "defaultValue": "https://localhost:55000"
    },
    {
      "name": "wazuh_user",
      "description": "User for Wazuh Manager",
      "type": "string",
      "multi": false,
      "required": true,
      "defaultValue": "wazuh-wui"
    },
    {
      "name": "wazuh_password",
      "description": "Password for Wazuh Manager",
      "type": "string",
      "multi": false,
      "required": true
    },
    {
      "name": "thehive_url",
      "description": "TheHive API URL for fetching case details",
      "type": "string",
      "multi": false,
      "required": false,
      "defaultValue": "https://172.24.80.95:8443"
    },
    {
      "name": "thehive_key",
      "description": "TheHive API key for fetching case details",
      "type": "string",
      "multi": false,
      "required": false
    }
  ],
  "config": {
    "wazuh_manager": "https://192.168.200.129:55000",
    "wazuh_user": "wazuh-wui",
    "wazuh_password": "WazuhSOC2024!",
    "thehive_url": "https://172.24.80.95:8443",
    "thehive_key": "SSZNE7qtAl6iBJNhls4Pvvt/iDuu7e+Y"
  }
}
